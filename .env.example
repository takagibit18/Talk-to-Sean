# Required
OPENAI_API_KEY=sk-your-provider-key
GITHUB_USERNAME=your-github-username

# Optional model provider settings
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GITHUB_PAT=

# Optional cost controls
DAILY_REQUEST_LIMIT=50
DAILY_IP_LIMIT=8
DAILY_SESSION_LIMIT=8
CHAT_ALLOWED_ORIGINS=

# Production quota storage. Configure either Upstash Redis REST or Vercel KV REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional local dev origins, comma-separated. Use LAN IPs only in development.
ALLOWED_DEV_ORIGINS=localhost:3000

# Provider examples
# OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek OpenAI-compatible API
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# OpenRouter OpenAI-compatible API
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key
# OPENAI_MODEL=openai/gpt-5-mini
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Self-hosted OpenAI-compatible gateway
# OPENAI_API_KEY=sk-local-placeholder
# OPENAI_MODEL=local-model
# OPENAI_BASE_URL=https://llm-gateway.example.com/v1
